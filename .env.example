# Copy this file to ".env" for LOCAL testing only.
# NEVER commit .env. In production these live in GitHub Secrets.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Supabase project (Settings -> API)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# OPTIONAL: where failure alerts are DM'd. Your own Telegram numeric user ID.
# Get it by messaging @userinfobot. Leave blank to disable alerts.
ALERT_CHAT_ID=
