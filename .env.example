# Copy this file to ".env" for LOCAL testing only.
# NEVER commit .env. In production these live in Coolify's env settings.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Postgres connection string for your self-hosted database.
# Coolify shows this on the database page as "Postgres URL (internal)".
# Example: postgres://postgres:PASSWORD@host:5432/postgres
DATABASE_URL=

# OPTIONAL: your Telegram numeric user ID for failure DMs (from @userinfobot)
ALERT_CHAT_ID=

# OPTIONAL: Awin datafeed URL(s), pipe-separated with |
AWIN_FEED_URLS=
