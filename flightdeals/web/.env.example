# --- required ---
DATABASE_URL=postgresql://flightdeals:CHANGE_ME@db:5432/flightdeals
AUTH_SECRET=                     # npx auth secret
SITE_BASE_URL=https://yourdomain.co.uk

# --- auth providers (each is optional; set at least one) ---
AUTH_RESEND_KEY=                 # Resend API key for magic-link email
AUTH_EMAIL_FROM=login@yourdomain.co.uk
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- billing ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLUS=               # price_xxx for the Plus subscription
STRIPE_PRICE_PRO=                # price_xxx for the Pro subscription

# --- live search (Pro) ---
LIVE_SEARCH_PROVIDER=serpapi     # serpapi | apify
SERPAPI_KEY=
APIFY_TOKEN=
APIFY_ACTOR=                     # e.g. someuser~google-flights-scraper

# --- affiliate ---
TRAVELPAYOUTS_MARKER=
