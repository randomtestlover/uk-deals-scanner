# --- required ---
DATABASE_URL=postgresql://flightdeals:CHANGE_ME@db:5432/flightdeals

# --- data sources ---
TRAVELPAYOUTS_TOKEN=            # travelpayouts.com API token (free)
TRAVELPAYOUTS_MARKER=           # your affiliate marker
KIWI_API_KEY=                   # Tequila API key (optional but recommended)

# --- telegram ---
TELEGRAM_BOT_TOKEN=             # @BotFather token
TELEGRAM_CHANNEL_ID=@your_channel
ADMIN_CHAT_ID=                  # your personal chat id for failure alerts

# --- alert emails (Resend) ---
RESEND_API_KEY=
ALERT_FROM_EMAIL=deals@yourdomain.co.uk

# --- misc ---
SITE_BASE_URL=https://yourdomain.co.uk
SHADOW_MODE=0                   # 1 = log, never post/alert
